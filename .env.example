# Festosh API
VITE_API_URL=/api
VITE_APP_DOMAIN=miyukini.com

# Server (used by server/index.ts)
NODE_ENV=development
# SECURITY: Must be at least 32 random characters in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE-ME-generate-a-random-32-plus-char-string
# SECURITY: Must be different from JWT_SECRET, at least 32 chars
ENCRYPTION_KEY=CHANGE-ME-generate-a-different-random-string
PORT=3001
DATABASE_PATH=./data/festosh.db

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3002

# SMTP (platform-level fallback for email sending)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM_EMAIL=noreply@festosh.com
# SMTP_FROM_NAME=Festosh
# SMTP_ENCRYPTION=tls

# OpenRouter API (for chatbot LLM)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://festosh.miyukini.com
